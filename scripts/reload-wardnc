#!/usr/bin/env bash
set -euo pipefail

WARDNC_BIN="${WARDNC_BIN:-/home/dxle/builds/wardnc/build/wardnc}"
WARDNC_RELOAD_SIGNAL="${WARDNC_RELOAD_SIGNAL:-SIGUSR1}"
PGREP_BIN="/usr/bin/pgrep"
KILL_BIN="/usr/bin/kill"
NOTIFY_SEND_BIN="${NOTIFY_SEND_BIN:-/home/dxle/bin/notify-send}"

WARDNC_NOTIFY_APP_NAME="${WARDNC_NOTIFY_APP_NAME:-reload-wardnc}"
WARDNC_NOTIFY_STACK_TAG="${WARDNC_NOTIFY_STACK_TAG:-reload-wardnc}"

usage() {
    printf 'Usage: %s [--dry-run]\n' "${0##*/}"
}

notify_error() {
    local message="$1"

    if [[ -x "$NOTIFY_SEND_BIN" ]]; then
        "$NOTIFY_SEND_BIN" \
            -a "$WARDNC_NOTIFY_APP_NAME" \
            -h "string:x-dunst-stack-tag:$WARDNC_NOTIFY_STACK_TAG" \
            -u critical \
            -t 4000 \
            "wardnc" \
            "$message" >/dev/null 2>&1 || true
    fi
}

collect_wardnc_pids() {
    {
        "$PGREP_BIN" -x wardnc 2>/dev/null || true
        "$PGREP_BIN" -f -- "$WARDNC_BIN" 2>/dev/null || true
    } | /usr/bin/awk 'NF { print $1 }' | /usr/bin/awk '!seen[$1]++'
}

validate_signal() {
    if [[ -z "$WARDNC_RELOAD_SIGNAL" ]]; then
        notify_error "wardnc reload signal is empty"
        exit 1
    fi

    if ! "$KILL_BIN" -l "$WARDNC_RELOAD_SIGNAL" >/dev/null 2>&1; then
        notify_error "invalid wardnc reload signal: $WARDNC_RELOAD_SIGNAL"
        exit 1
    fi
}

main() {
    local dry_run=0
    local pids=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run)
                dry_run=1
                shift
                ;;
            --help|-h)
                usage
                exit 0
                ;;
            *)
                usage >&2
                exit 2
                ;;
        esac
    done

    validate_signal
    mapfile -t pids < <(collect_wardnc_pids)

    if [[ "$dry_run" -eq 1 ]]; then
        printf 'signal=%s\n' "$WARDNC_RELOAD_SIGNAL"
        printf 'pids=%s\n' "${pids[*]:-none}"
        return 0
    fi

    if [[ ${#pids[@]} -eq 0 ]]; then
        notify_error "wardnc is not running"
        exit 1
    fi

    "$KILL_BIN" -s "$WARDNC_RELOAD_SIGNAL" "${pids[@]}"
}

main "$@"
